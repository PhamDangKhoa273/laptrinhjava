{
  "info": {
    "name": "BICAP Phase 2 Core",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection test tay cho Phase 2 core flow: auth, profile, admin users, farm approval."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "farmId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Phase2 Test User\",\n  \"email\": \"phase2user@example.com\",\n  \"password\": \"123456\",\n  \"phone\": \"0901234567\",\n  \"avatarUrl\": \"\"\n}"
        },
        "url": "{{baseUrl}}/auth/register"
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"phase2user@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Users - My Profile",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/users/me"
      }
    },
    {
      "name": "Users - Update My Profile",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Phase2 Updated User\",\n  \"phone\": \"0901111222\",\n  \"avatarUrl\": \"https://example.com/avatar.png\"\n}"
        },
        "url": "{{baseUrl}}/users/me/profile"
      }
    },
    {
      "name": "Admin - Get Users",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
        ],
        "url": "{{baseUrl}}/users"
      }
    },
    {
      "name": "Admin - Assign Role",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"roleName\": \"FARM\"\n}"
        },
        "url": "{{baseUrl}}/users/{{userId}}/roles"
      }
    },
    {
      "name": "Admin - Change User Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"INACTIVE\"\n}"
        },
        "url": "{{baseUrl}}/users/{{userId}}/status"
      }
    },
    {
      "name": "Admin - List Farms",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
        ],
        "url": "{{baseUrl}}/farms"
      }
    },
    {
      "name": "Admin - Approve Farm",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"approvalStatus\": \"APPROVED\"\n}"
        },
        "url": "{{baseUrl}}/farms/{{farmId}}/approval-status"
      }
    }
  ]
}
