# Production env example
# Copy to .env.prod and fill in real values. Do not commit secrets.

# Database
MYSQL_DATABASE=bicap_db
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
SPRING_DATASOURCE_USERNAME=root

# Backend security
APP_JWT_SECRET=replace-with-strong-random-jwt-secret
APP_JWT_EXPIRATION_MS=86400000
APP_JWT_REFRESH_EXPIRATION_MS=604800000
APP_CORS_ALLOWED_ORIGINS=https://your-domain.example
APP_FRONTEND_URL=https://your-domain.example
APP_ERRORS_INCLUDE_STACKTRACE=false
APP_DEMO_SEED_ENABLED=false
APP_DEMO_PASSWORD=

# Runtime / cache
SPRING_CACHE_TYPE=redis
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=true

# Uploads
APP_MEDIA_UPLOAD_DIR=/app/uploads
APP_MEDIA_MAX_FILE_SIZE_BYTES=5242880
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=5MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=5MB

# Actuator / observability
MANAGEMENT_ENDPOINTS_EXPOSE=health,info,metrics,prometheus
MANAGEMENT_HEALTH_DETAILS=when_authorized
APP_RATE_LIMIT_MAX_REQUESTS=60
APP_RATE_LIMIT_WINDOW_SECONDS=60

# Payments / subscriptions
APP_ORDER_DEPOSIT_GATEWAY_SECRET=replace-with-payment-secret
APP_SUBSCRIPTION_GATEWAY_SECRET=replace-with-subscription-secret

# Blockchain governance
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_CHAIN_ID=11155111

# VeChainThor integration
VECHAIN_THOR_ENABLED=false
VECHAIN_THOR_URL=
VECHAIN_THOR_DEV_PRIVATE_KEY=
VECHAIN_THOR_TO_ADDRESS=
